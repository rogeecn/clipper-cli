{
  "name": "clipper-cli",
  "version": "0.1.0",
  "description": "Plugin-first CLI for collecting web content with request and client fallback, then publishing to Markdown-based note systems.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "clipper",
    "web-clipping",
    "markdown",
    "obsidian",
    "siyuan",
    "playwright",
    "cli"
  ],
  "author": "Rogee",
  "repository": {
    "type": "git",
    "url": "https://github.com/rogeecn/clipper-cli.git"
  },
  "homepage": "https://github.com/rogeecn/clipper-cli#readme",
  "bugs": {
    "url": "https://github.com/rogeecn/clipper-cli/issues"
  },
  "bin": {
    "clipper": "dist/src/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "jsdom": "^26.0.0",
    "playwright": "^1.50.1",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.10",
    "@types/turndown": "^5.0.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
